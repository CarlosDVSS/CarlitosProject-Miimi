# Supabase → Settings → API (Project URL + Publishable key)
# Use só a chave sb_publishable_ no site — NUNCA a sb_secret_

VITE_SUPABASE_URL=https://SEU_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Na Vercel (se integração Supabase usar NEXT_PUBLIC_), também funciona:
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
